rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // PRIMITIVE DEFINITIONS & HELPERS
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == "barcelar34@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // DEFAULT DENY (Global Safety Net)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // CONNECTION TEST
    // ===============================================================
    match /test/connection {
      allow read: if true;
    }

    // ===============================================================
    // USERS
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'photoURL', 'id', 'createdAt', 'updatedAt']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.photoURL is string && data.photoURL.size() <= 1000 &&
             (data.bio == null || (data.bio is string && data.bio.size() <= 500)) &&
             data.id == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().id == existing().id &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'displayName', 'photoURL', 'bio', 'booksRead', 'pagesRead', 
                      'averageRating', 'favoriteGenre', 'lastReadDate', 'updatedAt', 
                      'favoriteBookId', 'readingStreak', 'profilePhoto', 'name'
                    ]);
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /recommendations/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) || isAdmin();
    }

    // ===============================================================
    // BOOKS
    // ===============================================================

    function isValidBook(data) {
      return data.userId == request.auth.uid &&
             data.titulo is string && data.titulo.size() > 0 && data.titulo.size() <= 500 &&
             data.autor is string && data.autor.size() > 0 && data.autor.size() <= 500 &&
             (data.pageCount == null || data.pageCount is number) &&
             (data.currentPage == null || data.currentPage is number) &&
             (data.totalPages == null || data.totalPages is number) &&
             (data.progressPercentage == null || data.progressPercentage is number);
    }

    match /books/{bookId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(bookId) && isValidBook(incoming());
      
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                    isValidBook(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'titulo', 'autor', 'mesLeitura', 'anoLeitura', 'genero', 'status', 
                      'notaGeral', 'resenha', 'pontosFortes', 'pontosFracos', 'citacaoFavorita', 
                      'favorito', 'notasDetalhadas', 'ilustracaoUrl', 'estiloIlustracao', 
                      'proporcaoIlustracao', 'coverUrl', 'coverSource', 'pageCount', 'description', 
                      'isbn', 'publisher', 'publishedDate', 'createdAt', 'updatedAt',
                      'currentPage', 'totalPages', 'progressPercentage', 'startedAt', 'finishedAt'
                    ]);
      
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ===============================================================
    // READING SESSIONS
    // ===============================================================

    function isValidSession(data) {
      return data.userId == request.auth.uid &&
             data.bookId is string &&
             data.pagesRead is number &&
             data.endPage is number &&
             data.date is number;
    }

    match /reading_sessions/{sessionId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSession(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidSession(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ===============================================================
    // GOALS & TRACKING
    // ===============================================================

    function isValidGoal(data) {
      return data.userId == request.auth.uid &&
             data.year is int && data.year >= 2020 && data.year <= 2100;
    }

    match /userGoals/{goalId} {
      allow get: if isSignedIn() && isValidId(goalId) && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && isValidGoal(incoming());
    }

    match /backupHistory/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /quotes/{quoteId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /shelves/{shelfId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
