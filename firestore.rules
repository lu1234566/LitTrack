rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // PHASES 3 & 4: PRIMITIVE DEFINITIONS & HELPERS
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == "barcelar34@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // DEFAULT DENY (Global Safety Net)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // CONNECTION TEST
    // ===============================================================
    match /test/connection {
      allow read: if true;
    }

    // ===============================================================
    // USERS & PROFILES
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'photoURL', 'id', 'createdAt', 'updatedAt']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.photoURL is string && data.photoURL.size() <= 1000 &&
             (data.bio == null || (data.bio is string && data.bio.size() <= 500)) &&
             data.id == request.auth.uid;
    }

    match /users/{userId} {
      // allow read: if isSignedIn() && isValidId(userId); // Simplified for get+list
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn(); // Relies on query filters and visibility logic in future, for now allowed for community
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'displayName', 'photoURL', 'bio', 'booksRead', 'pagesRead', 
                      'averageRating', 'favoriteGenre', 'lastReadDate', 'updatedAt', 
                      'communityPublic', 'showBooksPublicly', 'showStatsPublicly', 
                      'favoriteBookId', 'readingStreak', 'profilePhoto', 'name'
                    ]);
    }

    match /profiles/{userId} {
      allow read: if isSignedIn() && isValidId(userId);
      allow write: if isOwner(userId);
    }

    match /recommendations/{userId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) || isAdmin();
    }

    // ===============================================================
    // BOOKS
    // ===============================================================

    function isValidBook(data) {
      return data.userId == request.auth.uid &&
             data.titulo is string && data.titulo.size() > 0 && data.titulo.size() <= 500 &&
             data.autor is string && data.autor.size() > 0 && data.autor.size() <= 500 &&
             (data.pageCount == null || data.pageCount is number) &&
             (data.currentPage == null || data.currentPage is number) &&
             (data.totalPages == null || data.totalPages is number) &&
             (data.progressPercentage == null || data.progressPercentage is number);
    }

    match /books/{bookId} {
      allow get: if isSignedIn() && isValidId(bookId);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.isPublic == true); 
      
      allow create: if isSignedIn() && isValidId(bookId) && isValidBook(incoming());
      
      allow update: if isOwner(existing().userId) && isValidBook(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'titulo', 'autor', 'mesLeitura', 'anoLeitura', 'genero', 'status', 
                      'notaGeral', 'resenha', 'pontosFortes', 'pontosFracos', 'citacaoFavorita', 
                      'favorito', 'notasDetalhadas', 'ilustracaoUrl', 'estiloIlustracao', 
                      'proporcaoIlustracao', 'coverUrl', 'coverSource', 'pageCount', 'description', 
                      'isbn', 'publisher', 'publishedDate', 'createdAt', 'updatedAt',
                      'currentPage', 'totalPages', 'progressPercentage', 'startedAt', 'finishedAt'
                    ]);
      
      allow delete: if isOwner(existing().userId);
    }

    // ===============================================================
    // READING SESSIONS
    // ===============================================================

    function isValidSession(data) {
      return data.userId == request.auth.uid &&
             data.bookId is string &&
             data.pagesRead is number &&
             data.endPage is number &&
             data.date is number;
    }

    match /reading_sessions/{sessionId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSession(incoming());
      allow update: if isDocOwner() && isValidSession(incoming());
      allow delete: if isDocOwner();
    }

    // ===============================================================
    // GOALS & TRACKING
    // ===============================================================

    function isValidGoal(data) {
      return data.userId == request.auth.uid &&
             data.year is int && data.year >= 2020 && data.year <= 2100;
    }

    match /userGoals/{goalId} {
      allow get: if isSignedIn() && isValidId(goalId) && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && isValidGoal(incoming());
    }

    match /backupHistory/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    // ===============================================================
    // COMMUNITY & SOCIAL
    // ===============================================================

    function isValidFeedItem(data) {
      return data.userId == request.auth.uid &&
             data.content is string && data.content.size() <= 2000;
    }

    match /communityFeed/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidFeedItem(incoming());
      allow update: if (isSignedIn() && (
        (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'metadata', 'type', 'communityId'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount']))
      ));
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /likes/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(incoming().feedItemId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /comments/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(incoming().feedItemId);
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /communities/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (
        existing().ownerId == request.auth.uid ||
        incoming().diff(existing()).affectedKeys().hasOnly(['memberCount'])
      );
      allow delete: if isAdmin();
    }

    match /communityMembers/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (
        (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['sharedBookProgress', 'sharedBookFinished', 'lastProgressUpdate'])) ||
        (get(/databases/$(database)/documents/communities/$(existing().communityId)).data.ownerId == request.auth.uid)
      );
      allow delete: if isSignedIn() && (
        existing().userId == request.auth.uid || 
        get(/databases/$(database)/documents/communities/$(existing().communityId)).data.ownerId == request.auth.uid
      );
    }

    match /follows/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().followerId == request.auth.uid;
      allow delete: if isSignedIn() && existing().followerId == request.auth.uid;
    }

    // ===============================================================
    // CHALLENGES & BADGES
    // ===============================================================

    match /challenges/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /badges/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /userChallenges/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /userBadges/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && incoming().userId == request.auth.uid;
    }
  }
}
