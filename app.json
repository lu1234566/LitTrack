{
  "expo": {
    "name": "Readora Native",
    "slug": "readora-native",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "readora",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "package": "com.readora.mobile",
      "edgeToEdgeEnabled": true
    },
    "ios": {
      "bundleIdentifier": "com.readora.mobile",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-image-picker",
      "expo-media-library",
      "expo-notifications",
      "expo-camera"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
