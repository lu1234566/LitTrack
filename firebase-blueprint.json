{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "booksRead": { "type": "integer" },
        "pagesRead": { "type": "integer" },
        "averageRating": { "type": "number" },
        "favoriteGenre": { "type": "string" },
        "readingStreak": { "type": "integer" },
        "lastReadDate": { "type": "integer" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["id", "displayName", "photoURL", "createdAt", "updatedAt"]
    },
    "Book": {
      "title": "Book",
      "description": "A book log entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "titulo": { "type": "string" },
        "autor": { "type": "string" },
        "mesLeitura": { "type": "string" },
        "anoLeitura": { "type": "integer" },
        "genero": { "type": "string" },
        "status": { "type": "string" },
        "notaGeral": { "type": "number" },
        "resenha": { "type": "string" },
        "favorito": { "type": "boolean" },
        "pageCount": { "type": "integer" },
        "currentPage": { "type": "integer" },
        "totalPages": { "type": "integer" },
        "progressPercentage": { "type": "number" },
        "startedAt": { "type": "integer" },
        "finishedAt": { "type": "integer" },
        "createdAt": { "type": "object" },
        "dataCadastro": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["userId", "titulo", "autor", "status"]
    },
    "ReadingSession": {
      "title": "Reading Session",
      "description": "A reading session entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bookId": { "type": "string" },
        "bookTitle": { "type": "string" },
        "date": { "type": "integer" },
        "pagesRead": { "type": "integer" },
        "startPage": { "type": "integer" },
        "endPage": { "type": "integer" },
        "durationMinutes": { "type": "integer" },
        "mood": { "type": "string" },
        "quickNote": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["userId", "bookId", "date", "pagesRead"]
    },
    "UserGoal": {
      "title": "User Goal",
      "description": "Annual reading goals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "year": { "type": "integer" },
        "booksGoal": { "type": "integer" },
        "pagesGoal": { "type": "integer" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["userId", "year"]
    },
    "Shelf": {
      "title": "Shelf",
      "description": "User book shelves",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "accentColor": { "type": "string" },
        "coverImage": { "type": "string" },
        "bookIds": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["system", "custom"] },
        "sortOrder": { "type": "integer" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["userId", "name", "bookIds", "type", "createdAt", "updatedAt"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A book quote with personal notes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bookId": { "type": "string" },
        "bookTitle": { "type": "string" },
        "bookAuthor": { "type": "string" },
        "text": { "type": "string" },
        "page": { "type": "integer" },
        "personalNote": { "type": "string" },
        "moodLabel": { "type": "string" },
        "isFavorite": { "type": "boolean" },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "bookId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User account data and stats"
    },
    "/profiles/{userId}": {
      "schema": "LiteraryProfile",
      "description": "Literary DNA and reading analytics"
    },
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Books in user libraries"
    },
    "/userGoals/{goalId}": {
      "schema": "UserGoal",
      "description": "Annual reading goals"
    },
    "/quotes/{quoteId}": {
      "schema": "Quote",
      "description": "User book quotes and notes"
    },
    "/backupHistory/{backupId}": {
      "schema": "BackupHistory",
      "description": "User backup logs"
    },
    "/recommendations/{userId}": {
      "schema": "Recommendation",
      "description": "Analysis-based book recommendations"
    },
    "/retrospectives/{userId}": {
      "schema": "Retrospective",
      "description": "User annual retrospectives"
    },
    "/shelves/{shelfId}": {
      "schema": "Shelf",
      "description": "User book shelves"
    },
    "/reading_sessions/{sessionId}": {
      "schema": "ReadingSession",
      "description": "User reading history sessions"
    }
  }
}
