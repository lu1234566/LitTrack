{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "communityPublic": { "type": "boolean" },
        "showBooksPublicly": { "type": "boolean" },
        "showStatsPublicly": { "type": "boolean" },
        "booksRead": { "type": "integer" },
        "pagesRead": { "type": "integer" },
        "averageRating": { "type": "number" },
        "favoriteGenre": { "type": "string" },
        "favoriteBookId": { "type": "string" },
        "readingStreak": { "type": "integer" },
        "lastReadDate": { "type": "integer" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["id", "displayName", "photoURL", "createdAt", "updatedAt"]
    },
    "Book": {
      "title": "Book",
      "description": "A book log entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "titulo": { "type": "string" },
        "autor": { "type": "string" },
        "mesLeitura": { "type": "string" },
        "anoLeitura": { "type": "integer" },
        "genero": { "type": "string" },
        "status": { "type": "string" },
        "notaGeral": { "type": "number" },
        "resenha": { "type": "string" },
        "favorito": { "type": "boolean" },
        "createdAt": { "type": "object" },
        "dataCadastro": { "type": "integer" }
      },
      "required": ["userId", "titulo", "autor", "status"]
    },
    "UserGoal": {
      "title": "User Goal",
      "description": "Annual reading goals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "year": { "type": "integer" },
        "booksGoal": { "type": "integer" },
        "pagesGoal": { "type": "integer" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["userId", "year"]
    },
    "Community": {
      "title": "Community",
      "description": "A reading community",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "visibility": { "type": "string" },
        "inviteCode": { "type": "string" },
        "createdAt": { "type": "integer" },
        "memberCount": { "type": "integer" }
      },
      "required": ["name", "ownerId", "visibility", "inviteCode"]
    },
    "CommunityFeedItem": {
      "title": "Community Feed Item",
      "description": "An update in the community feed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "integer" },
        "likesCount": { "type": "integer" },
        "commentsCount": { "type": "integer" }
      },
      "required": ["userId", "content", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User account data and stats"
    },
    "/profiles/{userId}": {
      "schema": "LiteraryProfile",
      "description": "Literary DNA and AI profile"
    },
    "/books/{bookId}": {
      "schema": "Book",
      "description": "Books in user libraries"
    },
    "/userGoals/{goalId}": {
      "schema": "UserGoal",
      "description": "Annual reading goals"
    },
    "/backupHistory/{backupId}": {
      "schema": "BackupHistory",
      "description": "User backup logs"
    },
    "/recommendations/{userId}": {
      "schema": "Recommendation",
      "description": "AI book recommendations"
    },
    "/communityFeed/{itemId}": {
      "schema": "CommunityFeedItem",
      "description": "Social feed items"
    },
    "/communities/{communityId}": {
      "schema": "Community",
      "description": "Reading communities"
    },
    "/communityMembers/{memberId}": {
      "schema": "CommunityMember",
      "description": "Members of communities"
    },
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "Reactions to feed items"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on feed items"
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "User follow relationships"
    },
    "/userChallenges/{id}": {
      "schema": "UserChallenge",
      "description": "Tracked challenges for users"
    },
    "/userBadges/{id}": {
      "schema": "UserBadge",
      "description": "Badges earned by users"
    },
    "/challenges/{id}": {
      "schema": "Challenge",
      "description": "Global challenges"
    },
    "/badges/{id}": {
      "schema": "Badge",
      "description": "Global badges"
    }
  }
}
