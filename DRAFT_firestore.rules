rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // PHASES & PILLARS HELPERS
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == "barcelar34@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // DEFAULT DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // USERS & PROFILES
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'photoURL', 'createdAt', 'updatedAt']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.photoURL is string && data.photoURL.size() <= 1000 &&
             (data.bio == null || (data.bio is string && data.bio.size() <= 500));
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn(); // Filtering happens on resource fields
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'displayName', 'photoURL', 'bio', 'booksRead', 'pagesRead', 
                      'averageRating', 'favoriteGenre', 'lastReadDate', 'updatedAt', 
                      'communityPublic', 'showBooksPublicly', 'showStatsPublicly', 'favoriteBookId', 'readingStreak'
                    ]);
    }

    function isValidLiteraryProfile(data) {
      return data.generoFavorito is string && data.generoFavorito.size() <= 100 &&
             data.estiloLeitor is string && data.estiloLeitor.size() <= 100;
    }

    match /profiles/{userId} {
      allow read: if isSignedIn() && isValidId(userId);
      allow write: if isOwner(userId) && isValidLiteraryProfile(incoming());
    }

    match /recommendations/{userId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow write: if isOwner(userId) || isAdmin();
    }

    // ===============================================================
    // BOOKS
    // ===============================================================

    function isValidBook(data) {
      return data.userId == request.auth.uid &&
             data.titulo is string && data.titulo.size() > 0 && data.titulo.size() <= 200 &&
             data.autor is string && data.autor.size() > 0 && data.autor.size() <= 200 &&
             data.status in ['lido', 'lendo', 'quero ler'];
    }

    match /books/{bookId} {
      allow get: if isSignedIn() && isValidId(bookId);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(resource.data.userId)).data.showBooksPublicly == true);
      
      allow create: if isSignedIn() && isValidId(bookId) && isValidBook(incoming());
      
      allow update: if isOwner(existing().userId) && isValidBook(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'titulo', 'autor', 'mesLeitura', 'anoLeitura', 'genero', 'status', 
                      'notaGeral', 'resenha', 'pontosFortes', 'pontosFracos', 'citacaoFavorita', 
                      'favorito', 'notasDetalhadas', 'ilustracaoUrl', 'estiloIlustracao', 
                      'proporcaoIlustracao', 'coverUrl', 'coverSource', 'pageCount', 'description', 
                      'isbn', 'publisher', 'publishedDate'
                    ]);
      
      allow delete: if isOwner(existing().userId);
    }

    // ===============================================================
    // GOALS
    // ===============================================================

    function isValidGoal(data) {
      return data.userId == request.auth.uid &&
             data.year is int && data.year >= 2024 && data.year <= 2100;
    }

    match /userGoals/{goalId} {
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && isValidGoal(incoming());
    }

    // ===============================================================
    // SOCIAL & COMMUNITY
    // ===============================================================

    match /communityFeed/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if (isSignedIn() && (
        (incoming().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'metadata', 'type'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount', 'commentsCount']))
      ));
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /likes/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(incoming().feedItemId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /comments/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(incoming().feedItemId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /communities/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /communityMembers/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && (
        existing().userId == request.auth.uid || 
        get(/databases/$(database)/documents/communities/$(existing().communityId)).data.ownerId == request.auth.uid
      );
    }

    match /follows/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().followerId == request.auth.uid;
      allow delete: if isSignedIn() && existing().followerId == request.auth.uid;
    }

    // ===============================================================
    // SYSTEM & LOGS
    // ===============================================================

    match /backupHistory/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /challenges/{id} {
      allow read: if isSignedIn();
    }

    match /badges/{id} {
      allow read: if isSignedIn();
    }

    match /userChallenges/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /userBadges/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    // ===============================================================
    // INFRASTRUCTURE
    // ===============================================================
    match /test/connection {
      allow read: if true;
    }
  }
}
