# Readora Native — variáveis de ambiente
#
# IMPORTANTE: não commite o .env real. Para builds EAS, defina estas
# variáveis como Environment Variables no EAS (eas env:create) — não no git.
#
# Firebase: use os MESMOS valores do projeto do site (littrack-2026),
# que estão em .env.example (VITE_FIREBASE_*). São config pública de cliente.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Login Google (nativo). Pegue no Firebase Console:
#   Authentication > Sign-in method > Google > "Web SDK configuration" (Web client ID).
# Android exige um OAuth client Android (package com.readora.app + SHA-1 do EAS).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
