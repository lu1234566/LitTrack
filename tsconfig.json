{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "contexts/**/*.ts",
    "contexts/**/*.tsx",
    "services/**/*.ts",
    "types/**/*.ts",
    "theme/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "src",
    "dist",
    "android",
    "node_modules"
  ]
}
